{
  "manifest_version": 3,
  "name": "UofT Agent Connector",
  "version": "0.2.0",
  "description": "Extracts academic history from ACORN after the user logs in and prepares it for UofT Agent import.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://acorn.utoronto.ca/*",
    "https://uoft-agent-production.up.railway.app/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://acorn.utoronto.ca/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["utils/parser.js", "utils/domHelpers.js"],
      "matches": ["https://acorn.utoronto.ca/*"]
    }
  ]
}
